# Database (SQLite - no setup needed)
DATABASE_URL=sqlite+aiosqlite:///bdc_metrics.db
DATABASE_URL_SYNC=sqlite:///bdc_metrics.db

# SEC EDGAR - Required: provide your name and email for the User-Agent header
EDGAR_USER_AGENT=CompanyName admin@example.com

# Scheduler (cron expressions for update times, in US/Eastern timezone)
SCHEDULE_HOUR_1=6
SCHEDULE_HOUR_2=18
SCHEDULE_TIMEZONE=US/Eastern

# Logging
LOG_LEVEL=INFO
