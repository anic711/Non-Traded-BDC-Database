# Database
DATABASE_URL=postgresql+asyncpg://bdc_user:bdc_password@localhost:5432/bdc_metrics
DATABASE_URL_SYNC=postgresql+psycopg2://bdc_user:bdc_password@localhost:5432/bdc_metrics

# SEC EDGAR - Required: provide your name and email for the User-Agent header
EDGAR_USER_AGENT=CompanyName admin@example.com

# Scheduler (cron expressions for update times, in US/Eastern timezone)
SCHEDULE_HOUR_1=6
SCHEDULE_HOUR_2=18
SCHEDULE_TIMEZONE=US/Eastern

# Logging
LOG_LEVEL=INFO
